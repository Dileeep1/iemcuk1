{
  "name": "iemcuk-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @iemcuk/web run dev",
    "dev:api": "npm --workspace @iemcuk/api run dev",
    "build:web": "npm --workspace @iemcuk/web run build",
    "build:api": "npm --workspace @iemcuk/api run build",
    "lint:web": "npm --workspace @iemcuk/web run lint",
    "typecheck:api": "npm --workspace @iemcuk/api run typecheck"
  }
}
